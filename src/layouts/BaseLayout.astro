---
import '@fontsource-variable/inter';
import '@fontsource-variable/fraunces';
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  ogType?: 'website' | 'article';
  jsonLd?: Record<string, unknown>[];
  noindex?: boolean;
}
const { title, description, ogType, jsonLd, noindex } = Astro.props;

// Organización (Schema.org) presente en todas las páginas.
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'TramitaMex',
  url: Astro.site?.href,
  description: 'Guía informativa independiente sobre trámites en México.',
};
---

<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0f5132" />
    <SEO
      title={title}
      description={description}
      ogType={ogType}
      jsonLd={[orgSchema, ...(jsonLd ?? [])]}
      noindex={noindex}
    />
  </head>
  <body>
    <a href="#contenido" class="skip-link">Saltar al contenido</a>
    <Header />
    <main id="contenido">
      <slot />
    </main>
    <Footer />
  </body>
</html>
