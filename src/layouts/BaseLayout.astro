---
import '@fontsource-variable/inter';
import '@fontsource-variable/fraunces';
import interWoff2 from '@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url';
import frauncesWoff2 from '@fontsource-variable/fraunces/files/fraunces-latin-wght-normal.woff2?url';
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

export interface Props {
  title: string;
  description: string;
  ogType?: 'website' | 'article';
  jsonLd?: Record<string, unknown>[];
  noindex?: boolean;
  ogImage?: string;
  ogImageAlt?: string;
  ogImageWidth?: number;
  ogImageHeight?: number;
}
const { title, description, ogType, jsonLd, noindex, ogImage, ogImageAlt, ogImageWidth, ogImageHeight } =
  Astro.props;

// Organización (Schema.org) presente en todas las páginas.
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'TramitaMex',
  url: Astro.site?.href,
  description: 'Guía informativa independiente sobre trámites en México.',
  logo: {
    '@type': 'ImageObject',
    url: new URL('/favicon.svg', Astro.site).href,
  },
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'editorial',
    url: new URL('/contacto/', Astro.site).href,
  },
};
---

<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#0f5132" />
    <link rel="preload" href={interWoff2} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={frauncesWoff2} as="font" type="font/woff2" crossorigin />
    <SEO
      title={title}
      description={description}
      ogType={ogType}
      jsonLd={[orgSchema, ...(jsonLd ?? [])]}
      noindex={noindex}
      ogImage={ogImage}
      ogImageAlt={ogImageAlt}
      ogImageWidth={ogImageWidth}
      ogImageHeight={ogImageHeight}
    />
  </head>
  <body>
    <a href="#contenido" class="skip-link">Saltar al contenido</a>
    <Header />
    <main id="contenido">
      <slot />
    </main>
    <Footer />
  </body>
</html>
