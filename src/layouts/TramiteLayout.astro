---
import { Image, getImage } from 'astro:assets';
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import Faq from '../components/Faq.astro';
import Pasos from '../components/Pasos.astro';
import Relacionados from '../components/Relacionados.astro';
import TablaContenido from '../components/TablaContenido.astro';
import { getInstitucion } from '../data/instituciones';
import { getCardImage } from '../data/card-images';

interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface RelItem {
  slug: string;
  titulo: string;
  resumen: string;
  categoria?: string;
  costo?: string;
}

export interface Props {
  slug: string;
  titulo: string;
  tituloLargo?: string;
  tituloSeo?: string;
  descripcion: string;
  resumen: string;
  categoria: string;
  institucion: string;
  nivel: string;
  costo: string;
  modalidad: string;
  tiempo: string;
  vigencia?: string;
  urlOficial: string;
  urlOficialTexto: string;
  actualizado: Date;
  publicado?: Date;
  revisadoPor?: string;
  faq: { pregunta: string; respuesta: string }[];
  fuentes: { titulo: string; url: string }[];
  pasos?: { titulo: string; detalle: string }[];
  // Datos calculados que inyecta la ruta [tramite].astro:
  headings?: Heading[];
  lecturaMin?: number;
  relacionadosData?: RelItem[];
  guias?: { slug: string; titulo: string }[];
}

const p = Astro.props;
const h1 = p.tituloLargo ?? p.titulo;
const institucion = getInstitucion(p.institucion);
const pasos = p.pasos ?? [];
const relacionados = p.relacionadosData ?? [];
const guias = p.guias ?? [];

// Imagen temática del trámite (la misma foto de la ficha): encabezado + og:image.
const heroImage = getCardImage(p.slug);
const OG_WIDTH = 1200;
const ogHeight = Math.round((OG_WIDTH * heroImage.height) / heroImage.width);
// Versión JPG para redes sociales (mejor compatibilidad que WebP en scrapers).
const ogGenerated = await getImage({ src: heroImage, width: OG_WIDTH, format: 'jpeg', quality: 70 });
const ogImageUrl = new URL(ogGenerated.src, Astro.site).href;

const fmtFecha = new Intl.DateTimeFormat('es-MX', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const actualizadoTexto = fmtFecha.format(p.actualizado);

// Índice "En esta guía": encabezados H2 del cuerpo + secciones generadas.
const tocItems = [
  ...(p.headings ?? [])
    .filter((h) => h.depth === 2)
    .map((h) => ({ slug: h.slug, text: h.text })),
  ...(pasos.length ? [{ slug: 'paso-a-paso', text: 'Paso a paso' }] : []),
  ...(p.faq.length ? [{ slug: 'faq-title', text: 'Preguntas frecuentes' }] : []),
  ...(relacionados.length
    ? [{ slug: 'tramites-relacionados', text: 'Trámites relacionados' }]
    : []),
];

// Convierte el "tiempo" en español a una duración ISO 8601 (schema HowTo).
function tiempoAISO(tiempo: string): string | undefined {
  const t = tiempo.toLowerCase();
  if (t.includes('inmediat') || t.includes('al instante') || t.includes('mismo día')) return 'PT1H';
  const nums = (t.match(/\d+/g) ?? []).map(Number);
  if (nums.length === 0) return undefined;
  const n = Math.max(...nums);
  if (t.includes('minuto')) return `PT${n}M`;
  if (t.includes('hora')) return `PT${n}H`;
  if (t.includes('semana')) return `P${n}W`;
  if (t.includes('mes')) return `P${n}M`;
  if (t.includes('año')) return `P${n}Y`;
  if (t.includes('día') || t.includes('dia')) return `P${n}D`;
  return undefined;
}

// Extrae el costo numérico (MXN) para el schema HowTo.
function costoAMonto(costo: string): string | undefined {
  if (/gratis|sin costo|gratuito/i.test(costo)) return '0';
  const m = costo.replace(/[\s,]/g, '').match(/\d+(\.\d+)?/);
  return m ? m[0] : undefined;
}
const totalTime = tiempoAISO(p.tiempo);
const estimatedCost = costoAMonto(p.costo);

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: h1,
  description: p.descripcion,
  inLanguage: 'es-MX',
  datePublished: (p.publicado ?? p.actualizado).toISOString(),
  dateModified: p.actualizado.toISOString(),
  speakable: {
    '@type': 'SpeakableSpecification',
    cssSelector: ['.lead', '.ficha-list'],
  },
  image: {
    '@type': 'ImageObject',
    url: ogImageUrl,
    width: OG_WIDTH,
    height: ogHeight,
  },
  author: {
    '@type': 'Organization',
    name: 'Equipo editorial TramitaMex',
    url: new URL('/acerca-de/', Astro.site).href,
  },
  publisher: {
    '@type': 'Organization',
    name: 'TramitaMex',
    url: Astro.site?.href,
    logo: {
      '@type': 'ImageObject',
      url: new URL('/favicon.svg', Astro.site).href,
    },
  },
};

// Schema HowTo: ayuda a Google a mostrar el paso a paso como guía enriquecida.
const howToSchema =
  pasos.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'HowTo',
        name: h1,
        description: p.descripcion,
        inLanguage: 'es-MX',
        ...(totalTime ? { totalTime } : {}),
        ...(estimatedCost !== undefined
          ? {
              estimatedCost: { '@type': 'MonetaryAmount', currency: 'MXN', value: estimatedCost },
            }
          : {}),
        step: pasos.map((paso, i) => ({
          '@type': 'HowToStep',
          position: i + 1,
          name: paso.titulo,
          text: paso.detalle,
        })),
      }
    : null;

const ficha = [
  { etiqueta: 'Costo', valor: p.costo, destacado: true },
  { etiqueta: 'Modalidad', valor: p.modalidad },
  { etiqueta: 'Tiempo', valor: p.tiempo },
  { etiqueta: 'Vigencia', valor: p.vigencia },
  { etiqueta: 'Nivel', valor: p.nivel },
  { etiqueta: 'Institución', valor: institucion?.nombre ?? p.institucion },
].filter((f) => f.valor);

const govServiceSchema = {
  '@context': 'https://schema.org',
  '@type': 'GovernmentService',
  name: h1,
  description: p.descripcion,
  serviceType: p.titulo,
  inLanguage: 'es-MX',
  areaServed: { '@type': 'Country', name: 'México' },
  audience: { '@type': 'Audience', audienceType: 'Ciudadanía mexicana' },
  ...(institucion
    ? {
        provider: {
          '@type': 'GovernmentOrganization',
          name: institucion.nombreCompleto,
          alternateName: institucion.nombre,
          url: institucion.sitioOficial,
        },
      }
    : {}),
  availableChannel: {
    '@type': 'ServiceChannel',
    serviceUrl: p.urlOficial,
    name: p.urlOficialTexto,
  },
};

const jsonLd = [articleSchema, govServiceSchema, ...(howToSchema ? [howToSchema] : [])];
---

<BaseLayout
  title={p.tituloSeo ?? h1}
  description={p.descripcion}
  ogType="article"
  jsonLd={jsonLd}
  ogImage={ogImageUrl}
  ogImageAlt={h1}
  ogImageWidth={OG_WIDTH}
  ogImageHeight={ogHeight}
>
  <article class="tramite">
    <div class="tramite-hero">
      <div class="container hero-grid">
        <div class="hero-text">
        <Breadcrumbs
          items={[{ nombre: 'Trámites', href: '/tramites/' }, { nombre: p.titulo }]}
        />
        <p class="eyebrow">{p.categoria}</p>
        <h1>{h1}</h1>
        <p class="lead">{p.resumen}</p>

        <div class="hero-meta">
          {
            p.lecturaMin && (
              <span class="meta-item">
                <svg width="15" height="15" viewBox="0 0 16 16" aria-hidden="true">
                  <circle cx="8" cy="8" r="6.25" fill="none" stroke="currentColor" stroke-width="1.4" />
                  <path d="M8 4.5V8l2.5 1.5" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                {p.lecturaMin} min de lectura
              </span>
            )
          }
          {
            p.revisadoPor && (
              <span class="meta-item">
                <svg width="15" height="15" viewBox="0 0 16 16" aria-hidden="true">
                  <path d="M2 8.5 6 12l8-8.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                Revisado por <a href="/acerca-de/">{p.revisadoPor}</a>
              </span>
            )
          }
          <span class="meta-item">
            <svg width="15" height="15" viewBox="0 0 16 16" aria-hidden="true">
              <rect x="2.25" y="3" width="11.5" height="11" rx="1.75" fill="none" stroke="currentColor" stroke-width="1.4" />
              <path d="M2.25 6.25h11.5M5.5 1.75v2.5M10.5 1.75v2.5" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
            </svg>
            Actualizado el {actualizadoTexto}
          </span>
        </div>

        <div class="hero-actions">
          <a
            href={p.urlOficial}
            class="btn btn-primary"
            target="_blank"
            rel="noopener noreferrer"
          >
            Ir al sitio oficial
            <span class="visually-hidden">(abre en otra pestaña)</span>
            <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M6 3h7v7M13 3 6.5 9.5M11 9.5V13H3V5h3.5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
        </div>
        <figure class="hero-figure">
          <Image
            src={heroImage}
            alt=""
            widths={[400, 700, 900]}
            sizes="(max-width: 920px) 92vw, 45vw"
            format="webp"
            quality={74}
            loading="eager"
            fetchpriority="high"
          />
        </figure>
      </div>
    </div>

    <div class="container tramite-body">
      <div class="tramite-content prose">
        <slot />

        <Pasos pasos={pasos} />

        <Faq items={p.faq} />

        {
          p.fuentes.length > 0 && (
            <section class="fuentes" aria-labelledby="fuentes-title">
              <h2 id="fuentes-title">Fuentes oficiales</h2>
              <ul role="list">
                {p.fuentes.map((f) => (
                  <li>
                    <a href={f.url} target="_blank" rel="noopener noreferrer">
                      {f.titulo}
                      <span class="visually-hidden">(abre en otra pestaña)</span>
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          )
        }

        <p class="actualizado-nota">
          Información verificada en {actualizadoTexto} con base en fuentes oficiales. Los
          requisitos y costos pueden cambiar; confirma siempre en el portal oficial antes de
          iniciar tu trámite.
        </p>

        <Relacionados items={relacionados} />
      </div>

      <aside class="tramite-aside">
        <TablaContenido items={tocItems} />

        <div class="ficha surface-card">
          <p class="ficha-title">Ficha rápida</p>
          <dl class="ficha-list">
            {
              ficha.map((f) => (
                <div class:list={['ficha-row', { 'is-highlight': f.destacado }]}>
                  <dt>{f.etiqueta}</dt>
                  <dd>{f.valor}</dd>
                </div>
              ))
            }
          </dl>
          <a
            href={p.urlOficial}
            class="btn btn-accent ficha-cta"
            target="_blank"
            rel="noopener noreferrer"
          >
            {p.urlOficialTexto}
            <span class="visually-hidden">(abre en otra pestaña)</span>
          </a>
        </div>

        {
          institucion && (
            <a class="aside-inst surface-card" href={`/instituciones/${institucion.slug}/`}>
              <span class="aside-inst-label">Institución responsable</span>
              <span class="aside-inst-name">{institucion.nombre}</span>
              <span class="aside-inst-full">{institucion.nombreCompleto}</span>
            </a>
          )
        }

        {
          guias.length > 0 && (
            <div class="aside-guias surface-card">
              <span class="aside-guias-label">
                Parte de {guias.length === 1 ? 'esta guía' : 'estas guías'}
              </span>
              <ul role="list">
                {guias.map((g) => (
                  <li>
                    <a href={`/guias/${g.slug}/`}>
                      {g.titulo}
                      <svg width="14" height="14" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8.5 4.5M12 8l-3.5 3.5" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          )
        }
      </aside>
    </div>
  </article>
</BaseLayout>

<style>
  .tramite-hero {
    background: linear-gradient(180deg, var(--color-primary-soft), transparent);
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-md) var(--space-xl);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.82fr);
    gap: var(--space-xl);
    align-items: stretch;
  }
  .hero-text { align-self: center; }
  .hero-figure {
    margin: 0;
    min-height: 320px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    border: 1px solid var(--color-border);
    background: var(--color-surface-2);
  }
  .hero-figure img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .tramite-hero .eyebrow { margin-top: var(--space-md); }
  .tramite-hero h1 {
    font-size: var(--text-3xl);
    margin-top: var(--space-2xs);
    max-width: 20ch;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs) var(--space-md);
    margin-top: var(--space-md);
    font-size: var(--text-sm);
    color: var(--color-text-faint);
  }
  .meta-item {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
  }
  .meta-item svg { color: var(--color-primary); }
  .meta-item a { color: inherit; text-decoration: underline; text-underline-offset: 2px; }
  .meta-item a:hover { color: var(--color-primary-strong); }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }

  .tramite-body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 320px;
    gap: var(--space-xl);
    padding-block: var(--space-xl);
    align-items: start;
  }

  /* Aside pegajoso */
  .tramite-aside {
    position: sticky;
    top: 5.5rem;
    display: grid;
    gap: var(--space-sm);
  }
  .ficha { padding: var(--space-md); }
  .ficha-title {
    font-family: var(--font-display);
    font-weight: var(--weight-semibold);
    font-size: var(--text-lg);
    margin-bottom: var(--space-sm);
  }
  .ficha-list { margin: 0; display: grid; gap: 0; }
  .ficha-row {
    display: flex;
    justify-content: space-between;
    gap: var(--space-sm);
    padding-block: 0.65rem;
    border-bottom: 1px dashed var(--color-border);
  }
  .ficha-row:last-of-type { border-bottom: none; }
  .ficha-row dt { color: var(--color-text-faint); font-size: var(--text-sm); }
  .ficha-row dd { margin: 0; font-weight: var(--weight-medium); text-align: right; font-size: var(--text-sm); }
  .ficha-row.is-highlight dd { color: var(--color-success); font-weight: var(--weight-bold); }
  .ficha-cta { width: 100%; margin-top: var(--space-md); }

  .aside-inst {
    display: grid;
    gap: 0.15rem;
    padding: var(--space-md);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--duration-fast), transform var(--duration-fast) var(--ease-out-expo);
  }
  .aside-inst:hover { border-color: var(--color-primary-tint); transform: translateY(-2px); }
  .aside-inst-label { font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.04em; color: var(--color-text-faint); }
  .aside-inst-name { font-family: var(--font-display); font-size: var(--text-lg); color: var(--color-primary-strong); font-weight: var(--weight-semibold); }
  .aside-inst-full { font-size: var(--text-sm); color: var(--color-text-soft); }

  .aside-guias { padding: var(--space-md); }
  .aside-guias-label { display: block; font-size: var(--text-xs); text-transform: uppercase; letter-spacing: 0.04em; color: var(--color-text-faint); margin-bottom: var(--space-2xs); }
  .aside-guias ul { margin: 0; padding: 0; list-style: none; display: grid; gap: 0.35rem; }
  .aside-guias a {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--color-primary-strong);
    text-decoration: none;
  }
  .aside-guias a:hover { color: var(--color-accent-text); }
  .aside-guias a svg { flex-shrink: 0; transition: transform var(--duration-fast) var(--ease-out-expo); }
  .aside-guias a:hover svg { transform: translateX(3px); }

  .fuentes { margin-top: var(--space-2xl); padding: var(--space-md); background: var(--color-surface-2); border-radius: var(--radius-lg); border: 1px solid var(--color-border); }
  .fuentes h2 { font-size: var(--text-lg); margin-bottom: var(--space-sm); }
  .fuentes ul { margin: 0; padding: 0; list-style: none; display: grid; gap: 0.5rem; }
  .fuentes a { font-size: var(--text-sm); }

  .actualizado-nota {
    margin-top: var(--space-lg);
    padding: var(--space-sm) var(--space-md);
    border-left: 3px solid var(--color-accent);
    background: var(--color-accent-soft);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    color: var(--color-text-soft);
  }

  /* El índice se oculta en móvil (la navegación por scroll es suficiente). */
  @media (max-width: 920px) {
    .hero-grid { grid-template-columns: 1fr; gap: var(--space-md); }
    .hero-figure { min-height: 0; aspect-ratio: 16 / 9; max-height: 300px; }
    .tramite-body { grid-template-columns: 1fr; gap: var(--space-lg); }
    .tramite-aside { position: static; order: -1; }
    .tramite-aside :global(.toc) { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-figure img { transition: none; }
  }
</style>
