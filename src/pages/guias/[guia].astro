---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import GuiaIcon from '../../components/GuiaIcon.astro';
import { getCollection } from 'astro:content';
import { GUIAS } from '../../data/guias';
import { getCardImage } from '../../data/card-images';

export async function getStaticPaths() {
  return GUIAS.map((g) => ({ params: { guia: g.slug }, props: { guia: g } }));
}

const { guia } = Astro.props;
const tramites = await getCollection('tramites');
const bySlug = new Map(tramites.map((t) => [t.id, t.data]));

// Foto representativa de cada guía (reutiliza la foto del trámite más ilustrativo).
const IMG_POR_GUIA: Record<string, string> = {
  'empezar-a-trabajar': 'nss',
  'viajar-al-extranjero': 'pasaporte',
  'comprar-auto-usado': 'licencia-de-conducir',
  'comprar-casa': 'infonavit',
  'documentos-basicos': 'curp',
  'tramites-estudiantes': 'becas-benito-juarez',
  'adultos-mayores': 'pension-bienestar',
  'extranjeros-en-mexico': 'residencia-temporal-mexico',
};
const heroImage = getCardImage(IMG_POR_GUIA[guia.slug] ?? guia.pasos[0]?.slug ?? 'default');

const pasos = guia.pasos
  .map((p) => {
    const d = bySlug.get(p.slug);
    return d
      ? { slug: p.slug, nota: p.nota, titulo: d.titulo, costo: d.costo, categoria: d.categoria }
      : null;
  })
  .filter((p) => p !== null);

const otras = GUIAS.filter((g) => g.slug !== guia.slug);
const h1 = guia.tituloLargo ?? guia.titulo;

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: guia.titulo,
  description: guia.descripcion,
  itemListElement: pasos.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: p!.titulo,
    url: new URL(`/${p!.slug}/`, Astro.site).href,
  })),
};
const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: h1,
  description: guia.descripcion,
  inLanguage: 'es-MX',
  isPartOf: { '@type': 'WebSite', name: 'TramitaMex', url: new URL('/', Astro.site).href },
};
---

<BaseLayout title={h1} description={guia.descripcion} jsonLd={[collectionSchema, itemListSchema]}>
  <section class="guia-hero">
    <div class="container hero-grid">
      <div class="hero-text">
        <Breadcrumbs items={[{ nombre: 'Guías', href: '/guias/' }, { nombre: guia.titulo }]} />
        <div class="guia-hero-head">
          <span class="guia-hero-icon"><GuiaIcon id={guia.icono} size={30} /></span>
          <div>
            <p class="eyebrow">Guía paso a paso</p>
            <h1>{h1}</h1>
          </div>
        </div>
        <p class="lead">{guia.resumen}</p>
        <p class="guia-count">{pasos.length} trámites en esta guía</p>
      </div>
      <figure class="hero-figure">
        <Image
          src={heroImage}
          alt=""
          widths={[400, 700, 900]}
          sizes="(max-width: 920px) 92vw, 45vw"
          format="webp"
          quality={74}
          loading="eager"
          fetchpriority="high"
        />
      </figure>
    </div>
  </section>

  <div class="container section guia-body">
    <ol class="guia-pasos" role="list">
      {
        pasos.map((p, i) => (
          <li class="guia-paso">
            <div class="gp-num" aria-hidden="true">{i + 1}</div>
            <a class="gp-card" href={`/${p!.slug}/`}>
              <div class="gp-top">
                <span class="gp-cat">{p!.categoria}</span>
                {p!.costo && <span class="gp-costo">{p!.costo}</span>}
              </div>
              <h2 class="gp-titulo">{p!.titulo}</h2>
              <p class="gp-nota">{p!.nota}</p>
              <span class="gp-link">
                Ver la guía del trámite
                <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8.5 4.5M12 8l-3.5 3.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </a>
          </li>
        ))
      }
    </ol>

    {
      guia.consejo && (
        <aside class="guia-consejo">
          <p class="gc-title">Consejo</p>
          <p>{guia.consejo}</p>
        </aside>
      )
    }

    <p class="guia-nota-legal">
      TramitaMex es un sitio informativo independiente. Cada paso te lleva al portal oficial
      correspondiente; verifica requisitos y costos en la fuente oficial antes de iniciar tu trámite.
    </p>

    <section class="otras-guias" aria-labelledby="otras-title">
      <h2 id="otras-title">Otras guías</h2>
      <div class="otras-grid">
        {
          otras.map((g) => (
            <a class="otra-card" href={`/guias/${g.slug}/`}>
              <span class="otra-icon"><GuiaIcon id={g.icono} size={22} /></span>
              <span class="otra-titulo">{g.titulo}</span>
            </a>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .guia-hero {
    background: linear-gradient(180deg, var(--color-primary-soft), transparent);
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-md) var(--space-xl);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.82fr);
    gap: var(--space-xl);
    align-items: stretch;
  }
  .hero-text { align-self: center; }
  .hero-figure {
    margin: 0;
    min-height: 300px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-card);
    border: 1px solid var(--color-border);
    background: var(--color-surface-2);
  }
  .hero-figure img { display: block; width: 100%; height: 100%; object-fit: cover; }
  @media (max-width: 920px) {
    .hero-grid { grid-template-columns: 1fr; gap: var(--space-md); }
    .hero-figure { min-height: 0; aspect-ratio: 16 / 9; max-height: 300px; }
  }
  .guia-hero-head {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-top: var(--space-md);
  }
  .guia-hero-icon {
    display: grid;
    place-items: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    color: var(--color-primary-strong);
    flex-shrink: 0;
    box-shadow: var(--shadow-sm);
  }
  .guia-hero h1 { font-size: var(--text-3xl); max-width: 20ch; }
  .lead {
    margin-top: var(--space-md);
    max-width: 62ch;
    font-size: var(--text-md);
    color: var(--color-text-soft);
  }
  .guia-count {
    margin-top: var(--space-sm);
    font-size: var(--text-sm);
    color: var(--color-text-faint);
  }

  .guia-body { max-width: 800px; }

  /* Timeline de pasos */
  .guia-pasos { list-style: none; margin: 0; padding: 0; display: grid; }
  .guia-paso {
    --num: 2.75rem;
    position: relative;
    display: grid;
    grid-template-columns: var(--num) 1fr;
    gap: var(--space-md);
    padding-bottom: var(--space-lg);
  }
  .guia-paso::before {
    content: '';
    position: absolute;
    left: calc(var(--num) / 2 - 1px);
    top: var(--num);
    bottom: 0;
    width: 2px;
    background: linear-gradient(var(--color-primary-tint), var(--color-border));
  }
  .guia-paso:last-child { padding-bottom: 0; }
  .guia-paso:last-child::before { display: none; }
  .gp-num {
    width: var(--num);
    height: var(--num);
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--color-primary-strong);
    color: var(--color-text-on-dark);
    font-family: var(--font-display);
    font-weight: var(--weight-bold);
    font-size: var(--text-lg);
    box-shadow: var(--shadow-sm);
    position: relative;
    z-index: 1;
  }
  .gp-card {
    display: grid;
    gap: 0.3rem;
    padding: var(--space-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow-xs);
    transition: transform var(--duration-normal) var(--ease-out-expo),
      box-shadow var(--duration-normal), border-color var(--duration-fast);
  }
  .gp-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary-tint);
  }
  .gp-top { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; flex-wrap: wrap; }
  .gp-cat {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-primary);
  }
  .gp-costo {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-success);
  }
  .gp-titulo { font-size: var(--text-lg); margin: 0; }
  .gp-nota { margin: 0; color: var(--color-text-soft); font-size: var(--text-sm); line-height: var(--leading-normal); }
  .gp-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.2rem;
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-primary-strong);
  }
  .gp-link svg { transition: transform var(--duration-fast) var(--ease-out-expo); }
  .gp-card:hover .gp-link svg { transform: translateX(3px); }

  /* Consejo */
  .guia-consejo {
    margin-top: var(--space-lg);
    padding: var(--space-md);
    border: 1px solid var(--color-border);
    border-left: 4px solid var(--color-success);
    background: var(--color-success-soft);
    border-radius: var(--radius-md);
  }
  .gc-title {
    font-family: var(--font-display);
    font-weight: var(--weight-semibold);
    color: var(--color-success);
    margin-bottom: 0.2rem;
  }
  .guia-consejo p:last-child { margin: 0; color: var(--color-text); }

  .guia-nota-legal {
    margin-top: var(--space-lg);
    padding: var(--space-sm) var(--space-md);
    border-left: 3px solid var(--color-accent);
    background: var(--color-accent-soft);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    color: var(--color-text-soft);
  }

  /* Otras guías */
  .otras-guias { margin-top: var(--space-2xl); }
  .otras-guias > h2 { font-size: var(--text-xl); margin-bottom: var(--space-md); }
  .otras-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-sm);
  }
  .otra-card {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: var(--space-sm) var(--space-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--duration-fast), transform var(--duration-fast) var(--ease-out-expo);
  }
  .otra-card:hover { border-color: var(--color-primary-tint); transform: translateY(-2px); }
  .otra-icon { color: var(--color-primary-strong); flex-shrink: 0; }
  .otra-titulo { font-size: var(--text-sm); font-weight: var(--weight-medium); }
</style>
