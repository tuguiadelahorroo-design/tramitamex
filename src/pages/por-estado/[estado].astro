---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import TramiteCard from '../../components/TramiteCard.astro';
import { ESTADOS } from '../../data/estados';
import { GUIAS } from '../../data/guias';
import { getDatosEstado } from '../../data/estados-datos';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  return ESTADOS.map((estado) => ({
    params: { estado: estado.slug },
    props: { estado },
  }));
}

const { estado } = Astro.props;
const datos = getDatosEstado(estado.slug);
const tramites = (await getCollection('tramites')).sort(
  (a, b) => a.data.orden - b.data.orden
);

// Estatales/municipales = el costo/portal/requisitos los define cada entidad o municipio.
// Federales = se hacen igual en todo el país.
const esLocal = (nivel: string) => /estatal|municipal/.test(nivel.toLowerCase());
const estatales = tramites.filter((t) => esLocal(t.data.nivel));
const federales = tramites.filter((t) => !esLocal(t.data.nivel));

const tramitesPagina = [...estatales, ...federales];
const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: `Trámites en ${estado.nombre}`,
    description: `Trámites federales y estatales en ${estado.nombre}, México.`,
    inLanguage: 'es-MX',
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: tramitesPagina.map((t, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        name: t.data.titulo,
        url: new URL(`/${t.id}/`, Astro.site).href,
      })),
    },
  },
];
---

<BaseLayout
  title={estado.nombre.length > 14
    ? `Trámites en ${estado.nombre}`
    : `Trámites en ${estado.nombre}: federales y estatales`}
  description={datos
    ? `Trámites en ${estado.nombre}: costos 2026, portales oficiales y guías. Federales (CURP, RFC, NSS) y estatales (licencia, placas, tenencia, verificación).`
    : `Trámites en ${estado.nombre}: cuáles son federales (iguales en todo el país) y cuáles estatales (licencia, placas, tenencia, verificación). Con enlaces y guías.`}
  jsonLd={jsonLd}
>
  <section class="page-hero">
    <div class="container">
      <Breadcrumbs
        items={[{ nombre: 'Por estado', href: '/por-estado/' }, { nombre: estado.nombre }]}
      />
      <p class="eyebrow">Estado · Capital: {estado.capital}</p>
      <h1>Trámites en {estado.nombre}</h1>
      <p class="lead">
        En {estado.nombre}, los trámites <strong>federales</strong> se hacen igual que en el resto
        del país, mientras que los <strong>estatales</strong> (licencia, placas, tenencia,
        verificación…) los define el gobierno de {estado.nombre}. Aquí tienes ambos.
      </p>
    </div>
  </section>

  <div class="container section">
    {
      datos && (
        <section class="datos-estado">
          <h2>
            Datos de {estado.nombre} <span class="datos-year">2026</span>
          </h2>
          <p class="datos-intro">{datos.intro}</p>
          <div class="datos-cols">
            <div>
              <h3>Costos de referencia</h3>
              <dl class="costo-list">
                {datos.costos.map((c) => (
                  <div class="costo-row">
                    <dt>{c.tramite}</dt>
                    <dd>{c.detalle}</dd>
                  </div>
                ))}
              </dl>
              <p class="datos-aviso">
                Montos aproximados 2026; confirma el importe vigente en el portal oficial antes de
                pagar.
              </p>
            </div>
            <div>
              <h3>Portales oficiales</h3>
              <ul class="datos-portales" role="list">
                {datos.portales.map((p) => (
                  <li>
                    <a href={p.url} target="_blank" rel="noopener noreferrer">
                      {p.nombre}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </section>
      )
    }

    <!-- ESTATALES (destacados) -->
    <section class="block">
      <h2>Trámites estatales y municipales en {estado.nombre}</h2>
      <p class="block-sub">
        Estos los gestiona el gobierno de {estado.nombre}: el costo, el portal y los requisitos
        cambian según el estado. En cada guía te explicamos el proceso general y cómo llegar al
        portal de tu entidad.
      </p>
      <div class="cards-grid">
        {
          estatales.map((t) => (
            <TramiteCard
              titulo={t.data.titulo}
              descripcion={t.data.resumen}
              slug={t.id}
              categoria={t.data.categoria}
              costo={t.data.costo}
              live={true}
            />
          ))
        }
      </div>
    </section>

    <!-- FEDERALES (enlaces compactos) -->
    <section class="block">
      <h2>Trámites federales (iguales en {estado.nombre})</h2>
      <p class="block-sub">
        Se realizan en línea o en oficinas federales y aplican en toda la República, sin importar
        tu estado.
      </p>
      <div class="fed-grid">
        {
          federales.map((t) => (
            <a class="fed-link" href={`/${t.id}/`}>
              <span class="fed-name">{t.data.titulo}</span>
              {t.data.costo && <span class="fed-costo">{t.data.costo}</span>}
            </a>
          ))
        }
      </div>
    </section>

    <!-- GUÍAS -->
    <section class="block">
      <h2>Guías útiles</h2>
      <p class="block-sub">Agrupan los trámites que necesitas según tu situación de vida.</p>
      <div class="guias-row">
        {
          GUIAS.map((g) => (
            <a class="guia-chip" href={`/guias/${g.slug}/`}>
              {g.titulo}
            </a>
          ))
        }
      </div>
    </section>

    <aside class="estado-nota">
      <p>
        <strong>¿Eres de {estado.nombre}?</strong> Si conoces un trámite local que deberíamos
        cubrir primero, <a href="/contacto/">escríbenos</a> y lo priorizamos.
      </p>
    </aside>
  </div>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(180deg, var(--color-primary-soft), transparent);
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-md) var(--space-xl);
  }
  .page-hero .eyebrow { margin-top: var(--space-md); }
  .page-hero h1 { margin-top: var(--space-2xs); font-size: var(--text-3xl); }
  .lead { margin-top: var(--space-sm); max-width: 64ch; font-size: var(--text-md); color: var(--color-text-soft); }

  .block { margin-bottom: var(--space-2xl); }
  .block h2 { font-size: var(--text-xl); }
  .block-sub { margin-block: 0.35rem var(--space-md); color: var(--color-text-soft); max-width: 70ch; }
  .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: var(--space-md); }

  /* Datos específicos del estado */
  .datos-estado {
    margin-bottom: var(--space-2xl);
    padding: var(--space-lg);
    background: var(--color-primary-soft);
    border: 1px solid var(--color-primary-tint);
    border-radius: var(--radius-xl);
  }
  .datos-estado > h2 { font-size: var(--text-xl); display: flex; align-items: center; gap: 0.5rem; }
  .datos-year {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: 0.04em;
    color: var(--color-primary-strong);
    background: var(--color-surface);
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-pill);
  }
  .datos-intro { margin-block: var(--space-sm) var(--space-md); color: var(--color-text-soft); max-width: 72ch; }
  .datos-cols { display: grid; grid-template-columns: 1.3fr 1fr; gap: var(--space-lg); }
  .datos-cols h3 { font-size: var(--text-md); margin-bottom: var(--space-sm); }
  .costo-list { display: grid; gap: 0; margin: 0; }
  .costo-row {
    display: grid;
    gap: 0.1rem;
    padding-block: 0.6rem;
    border-bottom: 1px dashed var(--color-primary-tint);
  }
  .costo-row:last-child { border-bottom: none; }
  .costo-row dt { font-weight: var(--weight-semibold); font-size: var(--text-sm); }
  .costo-row dd { margin: 0; font-size: var(--text-sm); color: var(--color-text-soft); }
  .datos-aviso { margin-top: var(--space-sm); font-size: var(--text-xs); color: var(--color-text-faint); }
  .datos-portales { margin: 0; padding: 0; list-style: none; display: grid; gap: 0.5rem; }
  .datos-portales a { font-size: var(--text-sm); }

  @media (max-width: 700px) {
    .datos-cols { grid-template-columns: 1fr; gap: var(--space-md); }
  }

  /* Federales: enlaces compactos */
  .fed-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 0.6rem; }
  .fed-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.7rem 0.9rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--duration-fast), transform var(--duration-fast) var(--ease-out-expo);
  }
  .fed-link:hover { border-color: var(--color-primary-tint); transform: translateY(-2px); }
  .fed-name { font-weight: var(--weight-medium); font-size: var(--text-sm); }
  .fed-costo { font-size: var(--text-xs); color: var(--color-text-faint); flex-shrink: 0; }

  /* Guías */
  .guias-row { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .guia-chip {
    padding: 0.5rem 0.95rem;
    border-radius: var(--radius-pill);
    background: var(--color-surface);
    border: 1px solid var(--color-border-strong);
    color: var(--color-text-soft);
    text-decoration: none;
    font-size: var(--text-sm);
    transition: all var(--duration-fast) var(--ease-out-expo);
  }
  .guia-chip:hover { border-color: var(--color-primary); color: var(--color-primary-strong); transform: translateY(-2px); }

  .estado-nota {
    margin-top: var(--space-md);
    padding: var(--space-md);
    background: var(--color-primary-soft);
    border-radius: var(--radius-lg);
  }
  .estado-nota p { margin: 0; color: var(--color-text-soft); }
</style>
