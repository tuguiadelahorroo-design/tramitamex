---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import TramiteCard from '../../components/TramiteCard.astro';
import CategoryIcon from '../../components/CategoryIcon.astro';
import { getCollection } from 'astro:content';
import { CATEGORIAS } from '../../data/navigation';
import { GUIAS } from '../../data/guias';

const tramites = await getCollection('tramites');
const dataPorSlug = new Map(tramites.map((t) => [t.id, t.data]));
---

<BaseLayout
  title="Todos los trámites de México"
  description="Directorio de trámites en México: identidad, SAT, IMSS, vehiculares, registro civil y más. Requisitos, costos y enlaces oficiales de cada trámite."
>
  <section class="page-hero">
    <div class="container">
      <Breadcrumbs items={[{ nombre: 'Trámites' }]} />
      <h1>Todos los trámites</h1>
      <p class="lead">
        Explora por categoría o busca el trámite que necesitas. Cada guía incluye requisitos,
        costo, paso a paso y el enlace al portal oficial.
      </p>
      <form class="page-search" role="search" data-search-form>
        <svg class="search-icon" width="20" height="20" viewBox="0 0 20 20" aria-hidden="true"><circle cx="9" cy="9" r="6" fill="none" stroke="currentColor" stroke-width="1.7"/><path d="m14 14 3.5 3.5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg>
        <input type="search" name="q" placeholder="Busca un trámite o guía…" aria-label="Buscar trámite o guía" data-search-input autocomplete="off" />
      </form>
      <p class="search-empty" data-search-empty hidden>
        No encontramos trámites ni guías con ese nombre. Prueba con otra palabra o
        <a href="/contacto/">sugiérenos uno</a>.
      </p>
    </div>
  </section>

  <div class="container section">
    {
      CATEGORIAS.map((cat) => (
        <section class="cat-block" id={cat.id} data-cat-block>
          <h2 class="cat-title">
            <CategoryIcon id={cat.id} size={24} /> {cat.titulo}
          </h2>
          <div class="cards-grid">
            {cat.items.map((item) => {
              const d = dataPorSlug.get(item.slug);
              return (
                <div data-card data-nombre={item.nombre.toLowerCase()} data-cat={cat.titulo.toLowerCase()}>
                  <TramiteCard
                    titulo={item.nombre}
                    descripcion={d?.resumen ?? 'Guía en preparación. Pronto publicaremos requisitos, costo y paso a paso.'}
                    slug={item.slug}
                    costo={d?.costo}
                    live={item.live}
                  />
                </div>
              );
            })}
          </div>
        </section>
      ))
    }

    <section class="cat-block" data-cat-block>
      <h2 class="cat-title">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 7v13"/><path d="M3 6a1 1 0 0 1 1-1h4.5a3 3 0 0 1 3.5 2 3 3 0 0 1 3.5-2H20a1 1 0 0 1 1 1v12a1 1 0 0 1-1 1h-5.5a2.5 2.5 0 0 0-3 0 2.5 2.5 0 0 0-3 0H4a1 1 0 0 1-1-1z"/></svg>
        Guías por situación
      </h2>
      <div class="cards-grid">
        {
          GUIAS.map((g) => (
            <div
              data-card
              data-nombre={`${g.titulo} ${g.resumen}`.toLowerCase()}
              data-cat="guías guia situación"
            >
              <a class="guia-mini" href={`/guias/${g.slug}/`}>
                <span class="guia-mini-tag">Guía</span>
                <h3 class="guia-mini-title">{g.titulo}</h3>
                <p class="guia-mini-desc">{g.resumen}</p>
                <span class="guia-mini-link">
                  Ver guía
                  <svg width="16" height="16" viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h9m0 0L8.5 4.5M12 8l-3.5 3.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
                </span>
              </a>
            </div>
          ))
        }
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(180deg, var(--color-primary-soft), transparent);
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-md) var(--space-xl);
  }
  .page-hero h1 { margin-top: var(--space-sm); font-size: var(--text-3xl); }
  .lead { margin-top: var(--space-sm); max-width: 60ch; font-size: var(--text-md); color: var(--color-text-soft); }

  .page-search {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: var(--space-lg);
    max-width: 520px;
    background: var(--color-surface);
    border: 1.5px solid var(--color-border-strong);
    border-radius: var(--radius-pill);
    padding: 0.7rem 1.1rem;
    box-shadow: var(--shadow-sm);
  }
  .page-search:focus-within { border-color: var(--color-primary); box-shadow: var(--shadow-md); }
  .search-icon { color: var(--color-text-faint); flex-shrink: 0; }
  .page-search input { flex: 1; border: none; background: none; outline: none; font-size: var(--text-base); min-width: 0; }
  .search-empty { margin-top: var(--space-md); color: var(--color-text-soft); }

  .cat-block { margin-bottom: var(--space-xl); scroll-margin-top: 6rem; }
  .cat-block[hidden] { display: none; }
  .cat-title { display: flex; align-items: center; gap: 0.6rem; font-size: var(--text-xl); margin-bottom: var(--space-md); }
  .cat-title :global(svg) { color: var(--color-primary); flex-shrink: 0; }
  .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: var(--space-md); }
  [data-card][hidden] { display: none; }

  /* Tarjeta de guía (se distingue de los trámites por el fondo) */
  .guia-mini {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    height: 100%;
    padding: var(--space-md);
    background: var(--color-primary-soft);
    border: 1px solid var(--color-primary-tint);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: transform var(--duration-normal) var(--ease-out-expo),
      box-shadow var(--duration-normal) var(--ease-out-expo);
  }
  .guia-mini:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
  .guia-mini-tag {
    align-self: start;
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-primary-strong);
    background: var(--color-surface);
    padding: 0.12rem 0.55rem;
    border-radius: var(--radius-pill);
  }
  .guia-mini-title { font-size: var(--text-lg); margin: 0; }
  .guia-mini-desc { font-size: var(--text-sm); color: var(--color-text-soft); margin: 0; flex-grow: 1; }
  .guia-mini-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    margin-top: 0.5rem;
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-primary-strong);
  }
  .guia-mini-link svg { transition: transform var(--duration-fast) var(--ease-out-expo); }
  .guia-mini:hover .guia-mini-link svg { transform: translateX(3px); }
</style>

<script>
  const input = document.querySelector('[data-search-input]') as HTMLInputElement | null;
  const cards = Array.from(document.querySelectorAll('[data-card]')) as HTMLElement[];
  const blocks = Array.from(document.querySelectorAll('[data-cat-block]')) as HTMLElement[];
  const empty = document.querySelector('[data-search-empty]') as HTMLElement | null;
  const form = document.querySelector('[data-search-form]') as HTMLFormElement | null;

  form?.addEventListener('submit', (e) => e.preventDefault());

  const normaliza = (s: string) =>
    s.normalize('NFD').replace(/[̀-ͯ]/g, '').toLowerCase().trim();

  function filtrar(query: string) {
    const q = normaliza(query);
    let visibles = 0;

    cards.forEach((card) => {
      const nombre = normaliza(card.dataset.nombre ?? '');
      const cat = normaliza(card.dataset.cat ?? '');
      const match = q === '' || nombre.includes(q) || cat.includes(q);
      card.hidden = !match;
      if (match) visibles++;
    });

    // Oculta categorías que se quedaron sin tarjetas visibles.
    blocks.forEach((block) => {
      const tieneVisibles = block.querySelector('[data-card]:not([hidden])');
      block.hidden = !tieneVisibles;
    });

    if (empty) empty.hidden = visibles !== 0;
  }

  // Lee ?q= del hero al cargar.
  const params = new URLSearchParams(window.location.search);
  const initial = params.get('q') ?? '';
  if (initial && input) {
    input.value = initial;
    filtrar(initial);
  }

  input?.addEventListener('input', () => filtrar(input.value));
</script>
