---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { INSTITUCIONES } from '../../data/instituciones';
---

<BaseLayout
  title="Trámites por institución: SAT, IMSS, RENAPO y más"
  description="Trámites organizados por institución del gobierno de México: SAT, IMSS, RENAPO, SRE, INE y SEP. Encuentra cada trámite con su dependencia responsable."
>
  <section class="page-hero">
    <div class="container">
      <Breadcrumbs items={[{ nombre: 'Instituciones' }]} />
      <h1>Trámites por institución</h1>
      <p class="lead">
        Cada trámite lo emite una dependencia. Aquí los organizamos por institución para que
        llegues más rápido a lo que buscas.
      </p>
    </div>
  </section>

  <div class="container section">
    <div class="inst-grid">
      {
        INSTITUCIONES.map((i) => (
          <a href={`/instituciones/${i.slug}/`} class="inst-card">
            <div class="inst-head">
              <span class="inst-abbr">{i.nombre}</span>
              <span class="inst-count">{i.tramites.length} trámite{i.tramites.length === 1 ? '' : 's'}</span>
            </div>
            <span class="inst-full">{i.nombreCompleto}</span>
            <p class="inst-desc">{i.descripcion}</p>
          </a>
        ))
      }
    </div>
  </div>
</BaseLayout>

<style>
  .page-hero {
    background: linear-gradient(180deg, var(--color-primary-soft), transparent);
    border-bottom: 1px solid var(--color-border);
    padding-block: var(--space-md) var(--space-xl);
  }
  .page-hero h1 { margin-top: var(--space-sm); font-size: var(--text-3xl); }
  .lead { margin-top: var(--space-sm); max-width: 60ch; font-size: var(--text-md); color: var(--color-text-soft); }

  .inst-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: var(--space-md); }
  .inst-card {
    display: grid;
    gap: 0.4rem;
    padding: var(--space-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    transition: all var(--duration-fast) var(--ease-out-expo);
  }
  .inst-card:hover { border-color: var(--color-primary-tint); transform: translateY(-3px); box-shadow: var(--shadow-md); }
  .inst-head { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; }
  .inst-abbr { font-family: var(--font-display); font-size: 1.5rem; font-weight: var(--weight-bold); color: var(--color-primary-strong); }
  .inst-count { font-size: var(--text-xs); color: var(--color-text-faint); background: var(--color-surface-3); padding: 0.15rem 0.5rem; border-radius: var(--radius-pill); }
  .inst-full { font-weight: var(--weight-medium); font-size: var(--text-sm); }
  .inst-desc { font-size: var(--text-sm); color: var(--color-text-soft); margin: 0; }
</style>
