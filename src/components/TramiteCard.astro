---
// Tarjeta de trámite usada en listados (home, índice, instituciones).
import { Image } from 'astro:assets';
import { getCardImage } from '../data/card-images';

export interface Props {
  titulo: string;
  descripcion: string;
  slug: string;
  categoria?: string;
  costo?: string;
  live?: boolean;
}
const { titulo, descripcion, slug, categoria, costo, live = true } = Astro.props;
const Tag = live ? 'a' : 'div';
const foto = getCardImage(slug);
---

<Tag class:list={['tramite-card', { 'is-soon': !live }]} href={live ? `/${slug}/` : undefined}>
  <div class="card-media">
    <Image src={foto} alt="" widths={[400, 800]} sizes="(max-width: 700px) 92vw, 380px" format="webp" quality={72} loading="lazy" />
  </div>
  <div class="card-top">
    {categoria && <span class="card-cat">{categoria}</span>}
    {!live && <span class="card-soon">Próximamente</span>}
  </div>
  <h3 class="card-title">{titulo}</h3>
  <p class="card-desc">{descripcion}</p>
  <div class="card-foot">
    {costo && live && <span class="card-cost">{costo}</span>}
    {live && (
      <span class="card-arrow" aria-hidden="true">
        Ver guía
        <svg width="16" height="16" viewBox="0 0 16 16"><path d="M3 8h9m0 0L8.5 4.5M12 8l-3.5 3.5" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </span>
    )}
  </div>
</Tag>

<style>
  .tramite-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    height: 100%;
    padding: var(--space-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow-card);
    transition: transform var(--duration-normal) var(--ease-out-expo), box-shadow var(--duration-normal) var(--ease-out-expo), border-color var(--duration-fast);
  }
  a.tramite-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
    border-color: var(--color-primary);
  }
  a.tramite-card:hover .card-title { color: var(--color-primary-strong); }
  .is-soon { opacity: 0.72; }
  .card-media {
    margin: calc(-1 * var(--space-md)) calc(-1 * var(--space-md)) 0.35rem;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: calc(var(--radius-lg) - 1px) calc(var(--radius-lg) - 1px) 0 0;
    background: var(--color-surface-2);
  }
  .card-media img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-normal) var(--ease-out-expo);
  }
  a.tramite-card:hover .card-media img { transform: scale(1.04); }
  @media (prefers-reduced-motion: reduce) {
    .card-media img { transition: none; }
    a.tramite-card:hover .card-media img { transform: none; }
  }
  .card-top { display: flex; align-items: center; justify-content: space-between; gap: 0.5rem; }
  .card-cat {
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-primary-strong);
    background: var(--color-primary-soft);
    padding: 0.2rem 0.6rem;
    border-radius: var(--radius-pill);
  }
  .card-soon {
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-accent-strong);
    background: var(--color-accent-soft);
    padding: 0.12rem 0.45rem;
    border-radius: var(--radius-pill);
    font-weight: var(--weight-semibold);
  }
  .card-title { font-size: var(--text-lg); margin: 0; transition: color var(--duration-fast) var(--ease-out-expo); }
  .card-desc {
    font-size: var(--text-sm);
    color: var(--color-text-soft);
    margin: 0;
    flex-grow: 1;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    overflow: hidden;
  }
  .card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 0.5rem;
    padding-top: 0.75rem;
    border-top: 1px solid var(--color-border);
  }
  .card-cost {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-success);
  }
  .card-arrow {
    margin-left: auto;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--color-primary-strong);
  }
  .card-arrow svg { transition: transform var(--duration-fast) var(--ease-out-expo); }
  a.tramite-card:hover .card-arrow svg { transform: translateX(3px); }
</style>
