---
// Íconos vectoriales (estilo línea) por guía. Usan currentColor.
export interface Props {
  id: string;
  size?: number;
  class?: string;
}
const { id, size = 24, class: className } = Astro.props;

const ICONS: Record<string, string> = {
  // Empezar a trabajar → portafolios
  trabajo:
    '<rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/><path d="M2 13h20"/>',
  // Viajar → avión de papel (enviar)
  viaje:
    '<path d="M22 2 11 13"/><path d="M22 2 15 22l-4-9-9-4 20-7z"/>',
  // Auto usado → automóvil
  auto:
    '<path d="M5 17H3c-.6 0-1-.4-1-1v-3.3c0-.5.1-1 .4-1.4l1.4-2.6c.3-.6.9-1 1.6-1h9.2c.6 0 1.2.2 1.6.7L19 11s2 .5 2.5.9c.3.3.5.7.5 1.1V16c0 .6-.4 1-1 1h-2"/><circle cx="7.5" cy="17" r="2"/><path d="M9.5 17h5"/><circle cx="16.5" cy="17" r="2"/>',
  // Documentos básicos → archivo con líneas
  documentos:
    '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><path d="M14 2v6h6"/><path d="M8 13h8"/><path d="M8 17h6"/>',
  // Estudiantes → birrete
  estudios:
    '<path d="M22 10 12 5 2 10l10 5 10-5z"/><path d="M6 12v5c0 1 2.7 2.5 6 2.5s6-1.5 6-2.5v-5"/><path d="M22 10v6"/>',
  // Adultos mayores → corazón (apoyo)
  mayores:
    '<path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>',
  // Comprar casa → casa con puerta
  casa:
    '<path d="m3 10.5 9-7.5 9 7.5"/><path d="M5 9.5V20a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V9.5"/><path d="M10 21v-6h4v6"/>',
  // Extranjeros en México → globo terráqueo
  mundo:
    '<circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
};

const inner = ICONS[id] ?? '';
---

<svg
  class={className}
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="1.6"
  stroke-linecap="round"
  stroke-linejoin="round"
  aria-hidden="true"
  set:html={inner}
/>
